---
import '@styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Podread',
  description = 'Podread publishes public-safe Chinese podcast reading notes and articles.'
} = Astro.props;

const socialLinks = [
  {
    href: 'https://github.com/myvyang',
    label: 'GitHub',
    icon: 'github'
  },
  {
    href: 'https://github.com/myvyang',
    label: 'X',
    icon: 'x'
  },
  {
    href: 'mailto:myvyang@gmail.com',
    label: '邮箱',
    icon: 'mail'
  }
];

const pageTitle = title === 'Podread' ? title : `${title} | Podread`;
const pathname = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'blog', active: pathname === '/' || pathname.startsWith('/episodes') },
  { href: '/ebook/', label: 'ebook', active: pathname.startsWith('/ebook') },
  { href: '/rss.xml', label: 'RSS', active: false }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/podread-mark.svg" />
    <link rel="alternate" type="application/rss+xml" title="Podread RSS" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-banner">
        <div class="banner-inner">
          <a class="banner-brand" href="/">podread</a>
          <nav class="banner-nav" aria-label="主导航">
            {
              navLinks.map((item) => (
                <a class:list={['banner-link', { 'is-active': item.active }]} href={item.href}>
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </header>
      <main class="page">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          {
            socialLinks.map((item) => (
              <a class="social-link" href={item.href} aria-label={item.label}>
                {item.icon === 'github' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.36 6.84 9.72.5.09.68-.22.68-.49 0-.24-.01-1.05-.01-1.9-2.78.62-3.37-1.22-3.37-1.22-.45-1.19-1.11-1.51-1.11-1.51-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.93.85.09-.67.35-1.12.64-1.38-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.04 1.03-2.76-.1-.26-.45-1.31.1-2.72 0 0 .85-.28 2.75 1.05A9.35 9.35 0 0 1 12 6.91c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.64 1.03 2.76 0 3.95-2.34 4.82-4.57 5.07.36.32.68.95.68 1.92 0 1.38-.01 2.49-.01 2.82 0 .27.18.59.69.49A10.16 10.16 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" />
                  </svg>
                )}
                {item.icon === 'x' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M13.78 10.47 21.2 2h-1.76l-6.44 7.35L7.86 2H2l7.78 11.12L2 22h1.76l6.8-7.76L16 22h5.86l-8.08-11.53Zm-2.41 2.75-.79-1.1L4.31 3.3h2.7l5.06 7.11.79 1.1 6.58 9.25h-2.7l-5.37-7.55Z" />
                  </svg>
                )}
                {item.icon === 'mail' && (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M4.75 5.5h14.5c.96 0 1.75.79 1.75 1.75v9.5c0 .96-.79 1.75-1.75 1.75H4.75A1.75 1.75 0 0 1 3 16.75v-9.5c0-.96.79-1.75 1.75-1.75Zm.06 1.5 6.07 5.02c.65.54 1.59.54 2.24 0L19.19 7H4.81Zm14.69 1.61-5.42 4.48a3.25 3.25 0 0 1-4.16 0L4.5 8.61v8.14c0 .14.11.25.25.25h14.5c.14 0 .25-.11.25-.25V8.61Z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </footer>
    </div>
  </body>
</html>
