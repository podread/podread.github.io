---
import type { CollectionEntry } from 'astro:content';

interface Props {
  episodes: CollectionEntry<'episodes'>[];
}

const { episodes } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Shanghai',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date);
---

{
  episodes.length > 0 ? (
    <div class="article-list">
      {episodes.map((episode) => {
        const href = `/episodes/${episode.data.podcast_slug}/${episode.data.episode_slug}/`;
        return (
          <article class="article-row">
            <h2 class="article-title">
              <a href={href}>{episode.data.title}</a>
            </h2>
            <div class="article-meta">
              <span>{episode.data.podcast}</span>
              <span>{formatDate(episode.data.published_at)}</span>
            </div>
            {episode.data.summary && (
              <p class="article-summary">{episode.data.summary}</p>
            )}
          </article>
        );
      })}
    </div>
  ) : (
    <div class="empty-state">还没有公开文章。导出脚本会把已授权内容写入这里。</div>
  )
}
