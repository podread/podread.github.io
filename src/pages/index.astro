---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import EpisodeList from '@components/EpisodeList.astro';

const episodes = (await getCollection('episodes'))
  .filter((episode) => episode.data.rights_status !== 'local_only')
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
  .slice(0, 12);
---

<BaseLayout title="Podread" currentPath="/">
  <div class="reader-home">
    <section class="reader-head">
      <h1>用中文读播客</h1>
      <p>每期节目整理成一篇中文文章，保留原始来源、播客名称和发布时间。</p>
    </section>

    <EpisodeList episodes={episodes} />
  </div>
</BaseLayout>
