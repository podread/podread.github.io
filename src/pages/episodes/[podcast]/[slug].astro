---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const episodes = (await getCollection('episodes')).filter(
    (episode) => episode.data.rights_status !== 'local_only'
  );

  return episodes.map((episode) => ({
    params: {
      podcast: episode.data.podcast_slug,
      slug: episode.data.episode_slug
    },
    props: { episode }
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Shanghai',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date);

const hasParticipants = episode.data.hosts.length > 0 || episode.data.guests.length > 0;
---

<BaseLayout title={episode.data.title}>
  <article class="episode-article">
    <header class="episode-header">
      <div class="episode-meta">
        <a href={`/shows/${episode.data.podcast_slug}/`}>{episode.data.podcast}</a>
        <span class="meta-separator" aria-hidden="true">·</span>
        <span>{formatDate(episode.data.published_at)}</span>
        <span class="meta-separator" aria-hidden="true">·</span>
        <a href={episode.data.episode_url}>原始节目</a>
      </div>
      <h1>{episode.data.title}</h1>
      {episode.data.summary && <p class="episode-summary">{episode.data.summary}</p>}
      {
        episode.data.tags.length > 0 && (
          <div class="tag-list">
            {episode.data.tags.map((tag: string) => (
              <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    {
      hasParticipants && (
        <section class="people-section" aria-labelledby="participants-title">
          <h2 id="participants-title" class="sr-only">主持人和嘉宾</h2>
          {episode.data.hosts.length > 0 && (
            <div class="people-group">
              <h3>主持人</h3>
              <div class="people-list">
                {episode.data.hosts.map((person) => (
                  <div class="person-item">
                    <div class="person-line">
                      {person.url ? <a class="person-name" href={person.url}>{person.name}</a> : <span class="person-name">{person.name}</span>}
                    </div>
                    {person.description && <p class="person-description">{person.description}</p>}
                  </div>
                ))}
              </div>
            </div>
          )}
          {episode.data.guests.length > 0 && (
            <div class="people-group">
              <h3>嘉宾</h3>
              <div class="people-list">
                {episode.data.guests.map((person) => (
                  <div class="person-item">
                    <div class="person-line">
                      {person.url ? <a class="person-name" href={person.url}>{person.name}</a> : <span class="person-name">{person.name}</span>}
                    </div>
                    {person.description && <p class="person-description">{person.description}</p>}
                  </div>
                ))}
              </div>
            </div>
          )}
        </section>
      )
    }

    {
      episode.data.mentioned_people.length > 0 && (
        <section class="people-section" aria-labelledby="mentioned-people-title">
          <h2 id="mentioned-people-title">提到的人物</h2>
          <div class="people-list">
            {episode.data.mentioned_people.map((person) => (
              <div class="person-item">
                <div class="person-line">
                  {person.url ? <a class="person-name" href={person.url}>{person.name}</a> : <span class="person-name">{person.name}</span>}
                  {person.role && <span class="person-label">{person.role}</span>}
                </div>
                {person.description && <p class="person-description">{person.description}</p>}
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="episode-body">
      <Content />
    </section>
  </article>
</BaseLayout>
